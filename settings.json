{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/block-public-push.sh",
            "if": "Bash(git push *)",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
