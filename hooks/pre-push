#!/bin/bash
# ABOUTME: Pre-push hook for Claude Code sessions
# ABOUTME: Final checks before pushing to remote repositories

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}🔍 Running pre-push checks...${NC}"

# Check for sensitive data one more time
if [ -f "$HOME/.claude/scripts/check_sensitive_data.py" ]; then
    echo "Checking for sensitive data in staged files..."
    python3 "$HOME/.claude/scripts/check_sensitive_data.py" 2>/dev/null
    if [ $? -ne 0 ]; then
        echo -e "${RED}❌ Sensitive data detected! Push aborted.${NC}"
        echo -e "${RED}   Run 'git diff --cached' to see staged changes${NC}"
        echo -e "${RED}   Check for hardcoded passwords, API keys, or tokens${NC}"
        exit 1
    fi
fi

# Check for generic naming patterns
if git diff --name-only HEAD origin/$(git rev-parse --abbrev-ref HEAD) 2>/dev/null | grep -E "(new_|improved_|fixed_|updated_|FINAL|NEW)" > /dev/null; then
    echo -e "${YELLOW}⚠️  Warning: Files with generic names detected${NC}"
    echo "   Consider renaming files to be more descriptive"
fi

# Check for uncommitted changes
if [ -n "$(git status --porcelain)" ]; then
    echo -e "${YELLOW}⚠️  Warning: You have uncommitted changes${NC}"
    echo "   These changes will NOT be pushed"
fi

# Verify documentation is up to date
# Note: Claude/ may be a symlink to external repo, so check if it's a real directory
if [ -d "Claude" ] && [ ! -L "Claude" ]; then
    last_doc_update=$(find Claude -name "*.md" -type f -exec stat -f "%m" {} \; 2>/dev/null | sort -n | tail -1)
    last_code_update=$(git log -1 --format=%at)
    if [ -n "$last_doc_update" ] && [ "$last_doc_update" -lt "$last_code_update" ]; then
        echo -e "${YELLOW}📝 Documentation may be outdated${NC}"
        echo "   Consider updating handover/todo documentation"
    fi
fi

echo -e "${GREEN}✅ Pre-push checks complete${NC}"

# Push to multiple remotes reminder (if applicable)
if git remote | grep -q "gitea\|gitlab\|backup"; then
    echo -e "\n${YELLOW}📤 Remember:${NC} This project uses multiple remotes"
    if [ -f "./push-all.sh" ]; then
        echo "   After this push completes, also run: ./push-all.sh"
    else
        echo "   Consider pushing to all remotes"
    fi
fi